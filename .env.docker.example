POSTGRES_DB=your_local_database
POSTGRES_USER=your_local_user
POSTGRES_PASSWORD=replace-with-local-postgres-password

DATABASE_URL=postgresql://your_local_user:replace-with-local-postgres-password@db:5432/your_local_database?schema=public
DIRECT_URL=postgresql://your_local_user:replace-with-local-postgres-password@db:5432/your_local_database?schema=public

NEXTAUTH_SECRET=replace-with-a-long-random-local-secret

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-local-admin-password
DEMO_ORGANIZER_EMAIL=owner@example.com
DEMO_ORGANIZER_PASSWORD=replace-with-local-demo-owner-password
